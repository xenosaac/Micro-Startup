# Optional overrides for an installed Micro Startup repo.
#
# Copy this file to:
#   .micro-startup/config.env
#
# Only create it if you need to override the defaults.

# Claude CLI binary or command name.
CLAUDE_BIN="${HOME}/.local/bin/claude"

# Claude model alias or full model name.
CLAUDE_MODEL="opus"

# Prefix used for writer branches.
WRITER_BRANCH_PREFIX="codex/micro-startup"

# Optional tmux session name. Defaults to micro-startup-<repo-name>.
# SESSION_NAME="micro-startup-my-repo"
